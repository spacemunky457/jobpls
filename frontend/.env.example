# Copy to .env.local for local overrides (gitignored by Vite automatically).
# In production set these as environment variables in the Render dashboard
# (render.yaml documents which ones need values).

# ── Backend API URL ────────────────────────────────────────────────────────────
# Leave blank in dev: Vite proxies /api/* → http://localhost:8000 (see vite.config.ts).
# Set in production to your Render backend URL:
# VITE_API_URL=https://jobpls-backend.onrender.com

# ── Supabase auth (production only) ───────────────────────────────────────────
# Leave blank in dev — the app uses the local /auth/signup + /auth/login endpoints.
# When set, the frontend switches to Supabase JS auth automatically.
# Get both values from Supabase dashboard → Project Settings → API.
# VITE_SUPABASE_URL=https://abcdefghijklmnop.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
