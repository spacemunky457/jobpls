# Copy to .env and adjust. All values have local-friendly defaults in settings.py,
# so an empty/absent .env runs on SQLite + dev auth + console email out of the box.

# --- Database ---
# Local default (SQLite):
DATABASE_URL=sqlite:///./jobpls.db
# Supabase Postgres (deploy):
# DATABASE_URL=postgresql+psycopg://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# --- Auth ---
# dev = we issue/verify our own JWTs; supabase = verify Supabase-issued JWTs
AUTH_MODE=dev
JWT_SECRET=change-me-to-a-long-random-string
# For AUTH_MODE=supabase, set ONE of these (from Supabase project settings):
# SUPABASE_JWT_SECRET=...
# SUPABASE_JWKS_URL=https://[PROJECT].supabase.co/auth/v1/.well-known/jwks.json

# --- CORS / app ---
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
APP_BASE_URL=http://localhost:5173

# --- Email (magic-link human-in-the-loop) ---
EMAIL_PROVIDER=console
# RESEND_API_KEY=re_...
# EMAIL_FROM=Jobpls <you@yourdomain.com>
