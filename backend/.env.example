# Copy to .env and adjust. All values have local-friendly defaults in settings.py,
# so an empty/absent .env runs on SQLite + dev auth + console email out of the box.
#
# For Render deployment, set these as environment variables in the Render dashboard
# (render.yaml documents which ones need values).

# ── Database ──────────────────────────────────────────────────────────────────
# Local default (SQLite, auto-created):
DATABASE_URL=sqlite:///./jobpls.db
# Supabase Postgres (deploy) — Project Settings → Database → Connection string (URI):
# DATABASE_URL=postgresql+psycopg://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# ── Auth ──────────────────────────────────────────────────────────────────────
# dev      = we issue/verify our own HS256 JWTs — good for local development
# supabase = verify Supabase-issued JWTs (set SUPABASE_JWT_SECRET or SUPABASE_JWKS_URL)
AUTH_MODE=dev
JWT_SECRET=change-me-to-a-long-random-string

# Supabase auth (AUTH_MODE=supabase) — set ONE of these:
# Option A (simpler): paste the JWT Secret from Supabase → Project Settings → API
# SUPABASE_JWT_SECRET=your-supabase-jwt-secret
# Option B: JWKS endpoint (rotates automatically)
# SUPABASE_JWKS_URL=https://[PROJECT].supabase.co/auth/v1/.well-known/jwks.json

# ── CORS / app ────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Production: ALLOWED_ORIGINS=https://jobpls-frontend.onrender.com,https://app.yourdomain.com

# Base URL used in magic-link emails (the frontend URL).
APP_BASE_URL=http://localhost:5173
# Production: APP_BASE_URL=https://jobpls-frontend.onrender.com

# ── Email ─────────────────────────────────────────────────────────────────────
# console = logs to terminal (dev), smtp = Gmail/SMTP, resend = Resend API
EMAIL_PROVIDER=console
# RESEND_API_KEY=re_...
# EMAIL_FROM=Jobpls <hello@yourdomain.com>

# ── Scheduler cadence (system-wide, per-user can override SCHEDULER_ENABLED) ──
# DISCOVERY_INTERVAL_HOURS=6
# SCORING_INTERVAL_MINUTES=30
# DIGEST_INTERVAL_HOURS=24

# ── Managed Claude key (future premium tier) ──────────────────────────────────
# MANAGED_CLAUDE_API_KEY=sk-ant-...
